        IF(INDEX(row, 1, 1) = "", "", 
          TEXTJOIN("", TRUE, 
            MAP(row, LAMBDA(cell, 
              IF(cell = CONCATENATE(CHAR(13), "| "), "", cell)
            ))
          )
        )
      ))
    ), 
    CHAR(13), 
    "|}"
  ),
